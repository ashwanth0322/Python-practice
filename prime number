num=int(input("enter a no:"))

if num <= 1:
    print("the given number is not a prime number")


else:
    is_prime=True

    for i in range(2,num):
        if num%i == 0:
            is_prime=False
            break

if is_prime:
    print("the given no is prime")
else:
    print("the given number is not a prime")

